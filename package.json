{
  "name": "streampulse",
  "version": "1.0.0",
  "description": "Real-time log streaming and monitoring tool built with Node.js streams",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "streampulse": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
