{
  "name": "streampulse",
  "version": "1.0.0",
  "description": "CLI and HTTP API: pipe logs from stdin, parse and filter, broadcast via Server-Sent Events",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "streampulse": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "node dist/cli.js",
    "dev:cli": "tsx src/cli.ts"
  },
  "keywords": [
    "logs",
    "streaming",
    "sse",
    "cli",
    "monitoring",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
